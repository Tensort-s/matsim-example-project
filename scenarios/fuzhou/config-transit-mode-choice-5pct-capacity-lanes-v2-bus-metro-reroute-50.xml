<?xml version="1.0" ?>
<!DOCTYPE config SYSTEM "http://www.matsim.org/files/dtd/config_v2.dtd">
<config>

	<module name="global">
		<param name="randomSeed" value="20260709" />
		<param name="coordinateSystem" value="EPSG:32650" />
	</module>

	<module name="network">
		<param name="inputNetworkFile" value="../../data/transit/fuzhou_transit_matsim_integrated_20260709_capacity_lanes_v2_split_modes/network_with_car_bus_metro.xml.gz" />
	</module>

	<module name="plans">
		<param name="inputPlansFile" value="../../data/matsim_routes/fuzhou_city_23_greenspace_grid_multi_activity_5pct/mode_choice_plans_bus_metro.xml.gz" />
	</module>

	<module name="transit">
		<param name="useTransit" value="true" />
		<param name="transitModes" value="bus,metro" />
		<param name="transitScheduleFile" value="../../data/transit/fuzhou_transit_matsim_integrated_20260709_capacity_lanes_v2_split_modes/transitSchedule.xml.gz" />
		<param name="vehiclesFile" value="../../data/transit/fuzhou_transit_matsim_integrated_20260709_capacity_lanes_v2_split_modes/transitVehicles.xml.gz" />
	</module>

	<module name="swissRailRaptor">
		<param name="useModeMappingForPassengers" value="true" />
		<parameterset type="modeMapping">
			<param name="passengerMode" value="bus" />
			<param name="routeMode" value="bus" />
		</parameterset>
		<parameterset type="modeMapping">
			<param name="passengerMode" value="metro" />
			<param name="routeMode" value="metro" />
		</parameterset>
	</module>

	<module name="controller">
		<param name="outputDirectory" value="output-fuzhou-transit-mode-choice-5pct-capacity-lanes-v2-bus-metro-roadcap10-reroute-50" />
		<param name="lastIteration" value="50" />
	</module>

	<module name="qsim">
		<param name="mainMode" value="car" />
		<param name="flowCapacityFactor" value="0.10" />
		<param name="storageCapacityFactor" value="0.10" />
		<param name="endTime" value="36:00:00" />
	</module>

	<module name="subtourModeChoice">
		<param name="modes" value="car,bus,metro,walk" />
		<param name="chainBasedModes" value="car" />
		<param name="considerCarAvailability" value="true" />
	</module>

	<module name="scoring">
		<parameterset type="activityParams" >
			<param name="activityType" value="h" />
			<param name="typicalDuration" value="12:00:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="w" />
			<param name="typicalDuration" value="08:00:00" />
			<param name="openingTime" value="07:00:00" />
			<param name="closingTime" value="19:00:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="w_night" />
			<param name="typicalDuration" value="08:00:00" />
			<param name="openingTime" value="20:00:00" />
			<param name="closingTime" value="33:00:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="school" />
			<param name="typicalDuration" value="07:00:00" />
			<param name="openingTime" value="07:00:00" />
			<param name="closingTime" value="18:30:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="shop" />
			<param name="typicalDuration" value="01:00:00" />
			<param name="openingTime" value="09:00:00" />
			<param name="closingTime" value="24:00:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="leisure" />
			<param name="typicalDuration" value="02:00:00" />
			<param name="openingTime" value="08:00:00" />
			<param name="closingTime" value="24:00:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="leisure_night" />
			<param name="typicalDuration" value="03:00:00" />
			<param name="openingTime" value="20:00:00" />
			<param name="closingTime" value="29:00:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="restaurant" />
			<param name="typicalDuration" value="01:00:00" />
			<param name="openingTime" value="10:00:00" />
			<param name="closingTime" value="27:00:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="medical" />
			<param name="typicalDuration" value="01:00:00" />
			<param name="openingTime" value="08:00:00" />
			<param name="closingTime" value="17:30:00" />
		</parameterset>
		<parameterset type="activityParams" >
			<param name="activityType" value="other" />
			<param name="typicalDuration" value="01:00:00" />
		</parameterset>
		<parameterset type="modeParams" >
			<param name="mode" value="car" />
			<param name="constant" value="0.0" />
			<param name="marginalUtilityOfTraveling_util_hr" value="-6.0" />
		</parameterset>
		<parameterset type="modeParams" >
			<param name="mode" value="bus" />
			<param name="constant" value="-0.5" />
			<param name="marginalUtilityOfTraveling_util_hr" value="-6.0" />
		</parameterset>
		<parameterset type="modeParams" >
			<param name="mode" value="metro" />
			<param name="constant" value="1.0" />
			<param name="marginalUtilityOfTraveling_util_hr" value="-4.0" />
		</parameterset>
		<parameterset type="modeParams" >
			<param name="mode" value="walk" />
			<param name="constant" value="-1.5" />
			<param name="marginalUtilityOfTraveling_util_hr" value="-8.0" />
			<param name="marginalUtilityOfDistance_util_m" value="-0.001" />
		</parameterset>
	</module>

	<module name="replanning">
		<param name="maxAgentPlanMemorySize" value="5" />
		<parameterset type="strategysettings" >
			<param name="strategyName" value="BestScore" />
			<param name="subpopulation" value="default" />
			<param name="weight" value="0.70" />
		</parameterset>
		<parameterset type="strategysettings" >
			<param name="strategyName" value="SubtourModeChoice" />
			<param name="subpopulation" value="default" />
			<param name="weight" value="0.15" />
			<param name="disableAfterIteration" value="40" />
		</parameterset>
		<parameterset type="strategysettings" >
			<param name="strategyName" value="ReRoute" />
			<param name="subpopulation" value="default" />
			<param name="weight" value="0.10" />
			<param name="disableAfterIteration" value="40" />
		</parameterset>
		<parameterset type="strategysettings" >
			<param name="strategyName" value="TimeAllocationMutator" />
			<param name="subpopulation" value="default" />
			<param name="weight" value="0.05" />
			<param name="disableAfterIteration" value="40" />
		</parameterset>
	</module>

</config>
